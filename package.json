{
  "name": "claude-engineering-skills",
  "version": "1.0.0",
  "description": "Self-driving plan-audit-fix loop with adaptive learning. 3 models: Claude + GPT-5.4 + Gemini 3.1 Pro.",
  "type": "module",
  "bin": {
    "claude-engineering-skills": "install.mjs"
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs tests/claudemd/*.test.mjs tests/install/*.test.mjs tests/stores/*.test.mjs",
    "audit": "node scripts/audit-loop.mjs",
    "audit:full": "node scripts/audit-full.mjs",
    "audit:plan": "node scripts/openai-audit.mjs plan",
    "audit:code": "node scripts/openai-audit.mjs code",
    "audit:rebuttal": "node scripts/openai-audit.mjs rebuttal",
    "audit:gemini-review": "node scripts/gemini-review.mjs review",
    "audit:gemini-ping": "node scripts/gemini-review.mjs ping",
    "audit:refine": "node scripts/refine-prompts.mjs",
    "audit:bandit": "node scripts/bandit.mjs stats",
    "audit:phase7": "node scripts/phase7-check.mjs",
    "audit:check-deps": "node scripts/check-deps.mjs",
    "memory:health": "node scripts/memory-health.mjs",
    "memory:health:json": "node scripts/memory-health.mjs --json",
    "context:check": "node scripts/check-context-drift.mjs --strict",
    "context:check:json": "node scripts/check-context-drift.mjs --format json",
    "context:check:sarif": "node scripts/check-context-drift.mjs --format sarif",
    "models:freshness": "node scripts/check-model-freshness.mjs",
    "models:freshness:json": "node scripts/check-model-freshness.mjs --format json",
    "models:check": "node scripts/check-model-freshness.mjs --strict",
    "check": "npm run context:check && npm run skills:check && npm test",
    "sync": "node scripts/sync-to-repos.mjs",
    "sync:dry": "node scripts/sync-to-repos.mjs --dry-run",
    "sync:check": "node scripts/check-sync.mjs",
    "skills:regenerate": "node scripts/sync-shared-audit-refs.mjs && node scripts/regenerate-skill-copies.mjs",
    "skills:check": "node scripts/check-skill-refs.mjs && node scripts/sync-shared-audit-refs.mjs --check && node scripts/regenerate-skill-copies.mjs --check",
    "audit:sync-shared-refs": "node scripts/sync-shared-audit-refs.mjs",
    "skills:manifest": "node scripts/build-manifest.mjs",
    "skills:manifest:check": "node scripts/build-manifest.mjs --check",
    "skills:index": "node scripts/skills-help.mjs --out docs/SKILLS-INDEX.md",
    "skills:help": "node scripts/skills-help.mjs",
    "arch:refresh": "node scripts/symbol-index/refresh.mjs",
    "arch:refresh:full": "node scripts/symbol-index/refresh.mjs --full",
    "arch:render": "node scripts/symbol-index/render-mermaid.mjs",
    "arch:drift": "node scripts/symbol-index/drift.mjs",
    "arch:duplicates": "node scripts/symbol-index/duplicates.mjs",
    "arch:prune": "node scripts/symbol-index/prune.mjs",
    "security:refresh": "node scripts/security-memory/refresh-incidents.mjs",
    "arch:spike": "node scripts/symbol-index/spike-extract.mjs"
  },
  "keywords": [
    "claude",
    "gpt",
    "openai",
    "audit",
    "code-review",
    "plan-review",
    "multi-model",
    "claude-code",
    "skill"
  ],
  "author": "Louis Strydom",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@google/genai": "^1.50.1",
    "@supabase/supabase-js": "^2.103.0",
    "codeowners-utils": "^1.0.2",
    "dotenv": "17.4.2",
    "micromatch": "^4.0.8",
    "openai": "6.34.0",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.8.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "dependency-cruiser": "^17.3.10",
    "pg": "^8.20.0",
    "ts-morph": "^28.0.0"
  }
}
