{
  "permissions": {
    "allow": [
      "Bash(node scripts/*)",
      "Bash(node --input-type=module *)",
      "Bash(node -e *)",
      "Bash(npm test*)",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(echo *)",
      "Bash(file *)",
      "Bash(SID=*)",
      "Bash(grep *)",
      "Bash(python3 *)",
      "Read(*)",
      "Edit(*)",
      "Write(docs/**)",
      "Write(scripts/**)",
      "Write(tests/**)",
      "Write(.claude/**)",
      "Write(CLAUDE.md)",
      "Write(.env.example)"
    ],
    "additionalDirectories": []
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/arch-memory-check.sh",
            "shell": "bash",
            "timeout": 12,
            "statusMessage": "Consulting architectural memory..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/quickfix-scan.mjs",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
